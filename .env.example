# DeepSeek API Key (required)
# Sign up at https://platform.deepseek.com to get your API key
DEEPSEEK_API=sk-your-api-key-here

# Base URL for DeepSeek API (optional — default: https://api.deepseek.com)
BASE_URL="https://api.deepseek.com"

# Main reasoning model for the agent (optional — default: deepseek-chat)
DEFAULT_PRO_MODEL="deepseek-v4-pro"

# Flash model used for conversation compaction (optional — default: deepseek-chat)
DEFAULT_FLASH_MODEL="deepseek-v4-flash"
